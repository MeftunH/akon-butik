NODE_ENV=development
PORT=4000
LOG_LEVEL=debug

DATABASE_URL=postgresql://akonbutik_app:devpassword@localhost:5432/akonbutik_dev?schema=public

REDIS_URL=redis://localhost:6379

# DIA — fill from kb.txt for dev, never commit real values
DIA_BASE_URL=https://akonbutik.ws.dia.com.tr/api/v3
DIA_USERNAME=akonwb
DIA_PASSWORD=
DIA_API_KEY=
DIA_FIRMA_KODU=1
DIA_DONEM_KODU=1

# Auth
JWT_ACCESS_SECRET=replace-me-min-32-chars-locally-only
JWT_REFRESH_SECRET=replace-me-min-32-chars-locally-only
ADMIN_SYNC_TOKEN=replace-me-min-32-chars-admin-token-please

# Admin first-login bootstrap. The seed creates admin@akonbutik.com with a
# placeholder hash; on the first POST /api/admin/auth/login that matches
# this password, AdminAuthService writes the real argon2 hash and the
# placeholder is gone. Rotate or unset this env after the first login in
# any shared environment.
ADMIN_BOOTSTRAP_PASSWORD=ChangeMeAtFirstLogin!

# Set to 'true' to skip BullMQ cron registration (useful in tests or local one-off runs)
DISABLE_DIA_CRON=false

# Payments
IYZICO_API_KEY=
IYZICO_SECRET_KEY=
IYZICO_BASE_URL=https://sandbox-api.iyzipay.com

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:3100

# Image storage — admin product photography
# Dev: relative path under apps/api, served by Fastify at /uploads
# Prod: /home/akonbutik/public_html/uploads, served by Apache directly
IMAGE_STORAGE_ROOT=./storage
IMAGE_PUBLIC_BASE_URL=http://localhost:4000/uploads
