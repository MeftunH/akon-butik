{
  "name": "@akonbutik/i18n",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./messages/tr": "./messages/tr.json",
    "./messages/en": "./messages/en.json"
  },
  "files": ["dist", "messages"],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsc -p tsconfig.json --watch",
    "lint": "eslint src",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "@akonbutik/config-eslint": "workspace:*",
    "@akonbutik/config-tsconfig": "workspace:*",
    "eslint": "^9.17.0",
    "typescript": "^5.7.2"
  }
}
