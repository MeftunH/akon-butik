  "devDependencies": {
    "@akonbutik/config-eslint": "workspace:*",
    "@akonbutik/config-tsconfig": "workspace:*",
    "@storybook/addon-essentials": "^8.4.7",
    "@storybook/addon-interactions": "^8.4.7",
    "@storybook/react-vite": "^8.4.7",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react-swc": "^3.7.2",
    "eslint": "^9.17.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "storybook": "^8.4.7",
    "typescript": "^5.7.2",
